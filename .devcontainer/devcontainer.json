{
  "name": "pysc2_devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "type=bind,source=${localWorkspaceFolder}/.devcontainer/.vscode-server,target=/home/vscode/.vscode-server"
  ],
  "runArgs": [
    "--runtime=nvidia"
  ],
  "remoteUser": "vscode"
}
